<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_restoran" model="ir.ui.view">
        <field name="name">res.users.form.inherit.restoran</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//notebook" position="inside">
                <page string="Akses Restoran POS">
                    <group>
                        <field name="restoran_role" widget="radio"/>
                        <field name="cabang_id" />
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>