<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========== BAHAN BAKU FORM ========== -->
    <record id="view_restoran_bahan_form" model="ir.ui.view">
        <field name="name">restoran.bahan.form</field>
        <field name="model">restoran.bahan</field>
        <field name="arch" type="xml">
            <form string="Bahan Baku">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nama Bahan"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Info Bahan">
                            <field name="code"/>
                            <field name="uom"/>
                            <field name="price_per_unit" widget="monetary"/>
                        </group>
                        <group string="Stok">
                            <field name="stock_qty"/>
                            <field name="min_stock"/>
                            <field name="stock_status" widget="badge"
                                   decoration-success="stock_status == 'available'"
                                   decoration-warning="stock_status == 'low'"
                                   decoration-danger="stock_status == 'empty'"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========== BAHAN BAKU TREE ========== -->
    <record id="view_restoran_bahan_tree" model="ir.ui.view">
        <field name="name">restoran.bahan.tree</field>
        <field name="model">restoran.bahan</field>
        <field name="arch" type="xml">
            <tree string="Bahan Baku"
                  decoration-danger="stock_status == 'empty'"
                  decoration-warning="stock_status == 'low'">
                <field name="code"/>
                <field name="name"/>
                <field name="uom"/>
                <field name="stock_qty"/>
                <field name="min_stock"/>
                <field name="stock_status" widget="badge"
                       decoration-success="stock_status == 'available'"
                       decoration-warning="stock_status == 'low'"
                       decoration-danger="stock_status == 'empty'"/>
                <field name="price_per_unit" widget="monetary"/>
            </tree>
        </field>
    </record>

    <!-- ========== BAHAN BAKU SEARCH ========== -->
    <record id="view_restoran_bahan_search" model="ir.ui.view">
        <field name="name">restoran.bahan.search</field>
        <field name="model">restoran.bahan</field>
        <field name="arch" type="xml">
            <search string="Cari Bahan">
                <field name="name"/>
                <field name="code"/>
                <filter name="low_stock" string="Stok Menipis"
                        domain="[('stock_status', '=', 'low')]"/>
                <filter name="empty" string="Stok Habis"
                        domain="[('stock_status', '=', 'empty')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_uom" string="Satuan" context="{'group_by':'uom'}"/>
                    <filter name="group_status" string="Status Stok" context="{'group_by':'stock_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ========== ACTION ========== -->
    <record id="action_restoran_bahan" model="ir.actions.act_window">
        <field name="name">Bahan Baku</field>
        <field name="res_model">restoran.bahan</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_low_stock': 0}</field>
    </record>
</odoo>
