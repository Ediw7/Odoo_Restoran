<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ==================== BAHAN BAKU ==================== -->
        <record id="bahan_beras" model="restoran.bahan">
            <field name="name">Beras Putih</field>
            <field name="code">BHN001</field>
            <field name="uom">kg</field>
            <field name="stock_qty">50</field>
            <field name="min_stock">10</field>
            <field name="price_per_unit">12000</field>
        </record>

        <record id="bahan_ayam" model="restoran.bahan">
            <field name="name">Ayam Potong</field>
            <field name="code">BHN002</field>
            <field name="uom">pcs</field>
            <field name="stock_qty">100</field>
            <field name="min_stock">20</field>
            <field name="price_per_unit">8000</field>
        </record>

        <record id="bahan_telur" model="restoran.bahan">
            <field name="name">Telur Ayam</field>
            <field name="code">BHN003</field>
            <field name="uom">pcs</field>
            <field name="stock_qty">200</field>
            <field name="min_stock">30</field>
            <field name="price_per_unit">2000</field>
        </record>

        <record id="bahan_mie" model="restoran.bahan">
            <field name="name">Mie Kuning</field>
            <field name="code">BHN004</field>
            <field name="uom">kg</field>
            <field name="stock_qty">20</field>
            <field name="min_stock">5</field>
            <field name="price_per_unit">15000</field>
        </record>

        <record id="bahan_minyak" model="restoran.bahan">
            <field name="name">Minyak Goreng</field>
            <field name="code">BHN005</field>
            <field name="uom">ltr</field>
            <field name="stock_qty">30</field>
            <field name="min_stock">5</field>
            <field name="price_per_unit">18000</field>
        </record>

        <!-- ==================== BOM (BILL OF MATERIALS) ==================== -->
        <!-- Nasi Goreng Spesial -->
        <record id="bom_nasi_goreng_beras" model="restoran.menu.bom.line">
            <field name="menu_id" ref="menu_nasi_goreng"/>
            <field name="bahan_id" ref="bahan_beras"/>
            <field name="qty">0.2</field> <!-- 200g per porsi -->
            <field name="sequence">10</field>
        </record>
        <record id="bom_nasi_goreng_telur" model="restoran.menu.bom.line">
            <field name="menu_id" ref="menu_nasi_goreng"/>
            <field name="bahan_id" ref="bahan_telur"/>
            <field name="qty">1</field>
            <field name="sequence">20</field>
        </record>
        <record id="bom_nasi_goreng_ayam" model="restoran.menu.bom.line">
            <field name="menu_id" ref="menu_nasi_goreng"/>
            <field name="bahan_id" ref="bahan_ayam"/>
            <field name="qty">0.125</field> <!-- 1/8 ayam per porsi -->
            <field name="sequence">30</field>
        </record>

        <!-- Mie Goreng Jawa -->
        <record id="bom_mie_goreng_mie" model="restoran.menu.bom.line">
            <field name="menu_id" ref="menu_mie_goreng"/>
            <field name="bahan_id" ref="bahan_mie"/>
            <field name="qty">0.15</field> <!-- 150g per porsi -->
            <field name="sequence">10</field>
        </record>
        <record id="bom_mie_goreng_telur" model="restoran.menu.bom.line">
            <field name="menu_id" ref="menu_mie_goreng"/>
            <field name="bahan_id" ref="bahan_telur"/>
            <field name="qty">1</field>
            <field name="sequence">20</field>
        </record>

        <!-- Ayam Goreng Kremes -->
        <record id="bom_ayam_goreng_ayam" model="restoran.menu.bom.line">
            <field name="menu_id" ref="menu_ayam_goreng"/>
            <field name="bahan_id" ref="bahan_ayam"/>
            <field name="qty">1</field>
            <field name="sequence">10</field>
        </record>
        <record id="bom_ayam_goreng_minyak" model="restoran.menu.bom.line">
            <field name="menu_id" ref="menu_ayam_goreng"/>
            <field name="bahan_id" ref="bahan_minyak"/>
            <field name="qty">0.1</field> <!-- 100ml per porsi -->
            <field name="sequence">20</field>
        </record>
    </data>
</odoo>
